{
  "name": "leetex",
  "displayName": "LeetEx",
  "version": "0.3.1",
  "description": "AI-powered coding learning OS — LeetCode session observer",
  "author": "LeetEx",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "analytics:test": "tsx scripts/test-analytics.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.5",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "plasmo": "0.90.5",
    "postcss": "^8.5.15",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.287",
    "@types/node": "22.10.2",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://leetcode.com/*"
    ],
    "permissions": [
      "storage"
    ]
  }
}
